<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 1. 日志输出路径（避免敏感数据写入磁盘） -->
    <property name="LOG_FILE" value="logs/medical-quality-control.log"/>

    <!-- 2. 控制台日志（仅输出关键信息） -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 3. 文件日志（自动脱敏） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/medical-quality-control-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- 重要：移除所有敏感字段 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <!-- 防止写入原始报告 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- 4. 安全日志规则 -->
    <logger name="com.medical.quality" level="DEBUG">
        <appender-ref ref="FILE"/>
        <appender-ref ref="STDOUT"/>
    </logger>

    <!-- 5. 严格过滤敏感信息 -->
    <logger name="com.medical.quality.service" level="DEBUG">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>SENSITIVE</marker>
            </evaluator>
            <onMatch>DENY</onMatch>  <!-- 拒绝记录包含SENSITIVE标记的日志 -->
        </filter>
    </logger>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>